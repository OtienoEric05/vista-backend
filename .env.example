# Copy to .env and fill in values.
# Only variables referenced in application code are listed below.

# --- server.js ---
PORT=5000
NODE_ENV=development
# Comma-separated browser origins (required in production). Append Vercel preview URLs as needed.
CORS_ORIGINS=https://vista-frontend-tau.vercel.app

# --- config/mongodb.js, seed.js ---
# Local:
MONGODB_URI=mongodb://127.0.0.1:27017/vistavoyage
# Atlas:
# MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER_HOST>/<DB_NAME>?retryWrites=true&w=majority

# --- lib/email.js ---
# Local SMTP (Mailpit / MailHog / MailDev):
# EMAIL_HOST=localhost
# EMAIL_PORT=1025
# EMAIL_ALLOW_NO_AUTH=true
# EMAIL_FROM=no-reply@vistavoyage.local
# EMAIL_USER=
# EMAIL_PASS=
#
# Production SMTP:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_ALLOW_NO_AUTH=false
EMAIL_FROM=your-email@example.com
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password

# --- controllers/contactController.js, appointmentController.js, bookingController.js ---
COMPANY_EMAIL=info@vistavoyagetravel.group

# --- lib/sms.js ---
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key
