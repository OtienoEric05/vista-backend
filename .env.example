# ==============================
# Server Configuration
# ==============================
PORT=5000

# ==============================
# MongoDB Configuration
# ==============================
# Local example:
# MONGODB_URI="mongodb://127.0.0.1:27017/vistavoyage"
# Live example (MongoDB Atlas):
# MONGODB_URI="mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER_HOST>/<DB_NAME>?retryWrites=true&w=majority"
MONGODB_URI="mongodb://127.0.0.1:27017/vistavoyage"

# ==============================
# Email Configuration (Gmail SMTP)
# ==============================
# EMAIL_USER should be your Gmail or business email
# EMAIL_PASS should be the Gmail App Password if 2FA is enabled
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password
COMPANY_EMAIL=info@vistavoyagetravel.group

# ==============================
# Africa's Talking (SMS API) Configuration
# ==============================
# For sandbox/testing mode use these values
# Replace with live credentials when deploying
AT_USERNAME=sandbox
AT_API_KEY="your-africastalking-api-key"
AT_SHORTCODE=VISTAVOYAGE