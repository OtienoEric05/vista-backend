# Copy to .env and fill in values.

# --- server.js ---
PORT=5000
NODE_ENV=production
# Comma-separated browser origins
CORS_ORIGINS=https://new.vistavoyagetravel.group

# --- Database ---
# Direct connection (current production):
MONGODB_URI=mongodb://vista:8EVRpr3vMLRFicd@vista-vista-uzlprp:27017/?authSource=admin&directConnection=true
# Atlas (alternative):
# MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER_HOST>/<DB_NAME>?retryWrites=true&w=majority
# Local dev:
# MONGODB_URI=mongodb://127.0.0.1:27017/vistavoyage

# ── SMTP (used by lib/emailService.js — booking confirmations & admin alerts) ──
# Gmail: use a 16-char App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_16_char_app_password

# Professional domain SMTP (Zoho / cPanel / Namecheap):
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=bookings@yourdomain.com
# SMTP_PASS=your_email_password

# Admin inbox — receives every new booking notification
ADMIN_EMAIL=otienoeric374@gmail.com

# Company display name shown in email "From" header
COMPANY_NAME=Vista Voyage

# ── Legacy email vars (used by lib/email.js for quote emails) ──────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_ALLOW_NO_AUTH=false
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=youremail@gmail.com
COMPANY_EMAIL=info@vistavoyagetravel.group

# Local dev SMTP (Mailpit / MailHog — no real emails sent):
# SMTP_HOST=localhost
# SMTP_PORT=1025
# EMAIL_HOST=localhost
# EMAIL_PORT=1025
# EMAIL_ALLOW_NO_AUTH=true

# --- SMS (Africa's Talking) ---
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key
